    <h2 class="mb-4 fw-bold">🏆 Lĩnh vực được đăng ký nhiều nhất tuần</h2>
    <div class="row">
        <div class="col-md-6">
            <ul class="list-group list-group-flush">
                {{#each topCategories}}
                <li class="list-group-item d-flex justify-content-between align-items-center fs-5 p-3">
                    <a href="/categories/{{this.id}}" class="text-decoration-none text-dark fw-bold">
                        {{this.catname}}
                    </a>
                    <span class="badge bg-primary rounded-pill">{{this.enroll_count}} lượt đăng ký</span>
                </li>
                {{/each}}
            </ul>
        </div>
    </div>

</div>