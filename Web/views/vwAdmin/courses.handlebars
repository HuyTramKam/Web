<h2 class="text-center mt-4 mb-4">Quản lý Khóa học</h2>

<div class="container">
  <!-- Bộ lọc + tìm kiếm -->
  <div class="row mb-3">
    <div class="col-md-4">
      <select class="form-select" id="categoryFilter">
        <option value="">Chọn lĩnh vực</option>
        {{#each categories}}
        <option value="{{this.name}}">{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    <div class="col-md-4">
      <input type="text" id="searchInput" class="form-control" placeholder="Tìm khóa học hoặc giảng viên...">
    </div>
  </div>

  <table class="table table-striped table-bordered align-middle">
    <thead class="table-dark">
      <tr class="text-center">
        <th>#</th>
        <th>Tên khóa học</th>
        <th>Lĩnh vực</th>
        <th>Giảng viên</th>
        <th>Trạng thái</th>
        <th>Hành động</th>
      </tr>
    </thead>
    <tbody id="courseTable">
      {{#each courses}}
      <tr>
        <td class="text-center">{{@index}}</td>
        <td>{{this.course_title}}</td>
        <td>{{this.category_name}}</td>
        <td>{{this.instructor_name}}</td>

        <!-- Hiển thị trạng thái -->
        <td class="text-center">
          {{#if this.is_disabled}}
            <span class="badge bg-danger">Đã bị đình chỉ</span>
          {{else}}
            <span class="badge bg-success">Đang hoạt động</span>
          {{/if}}
        </td>

        <!-- Cột hành động -->
        <td class="text-center">
          <!-- Nút Xóa -->
          <form action="/admin/courses/delete/{{this.id}}" method="POST" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa khóa học này?');">
            <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
          </form>

          <!-- Nút Đình chỉ / Mở lại -->
          {{#if this.is_disabled}}
          <form action="/admin/courses/disable/{{this.id}}" method="POST" style="display:inline;">
            <input type="hidden" name="disable" value="false">
            <button type="submit" class="btn btn-sm btn-success">Mở lại</button>
          </form>
          {{else}}
          <form action="/admin/courses/disable/{{this.id}}" method="POST" style="display:inline;">
            <input type="hidden" name="disable" value="true">
            <button type="submit" class="btn btn-sm btn-warning">Đình chỉ</button>
          </form>
          {{/if}}
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const categoryFilter = document.getElementById('categoryFilter');
  const searchInput = document.getElementById('searchInput');
  const rows = document.querySelectorAll('#courseTable tr');

  function filterTable() {
    const selectedCategory = categoryFilter.value.toLowerCase();
    const searchText = searchInput.value.toLowerCase();

    rows.forEach(row => {
      const category = row.cells[2]?.textContent.toLowerCase();
      const course = row.cells[1]?.textContent.toLowerCase();
      const instructor = row.cells[3]?.textContent.toLowerCase();

      const matchCategory = !selectedCategory || category.includes(selectedCategory);
      const matchSearch = !searchText || course.includes(searchText) || instructor.includes(searchText);

      row.style.display = matchCategory && matchSearch ? '' : 'none';
    });
  }

  categoryFilter.addEventListener('change', filterTable);
  searchInput.addEventListener('input', filterTable);
});
</script>
