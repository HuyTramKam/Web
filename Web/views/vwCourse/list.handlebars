<h2 class="text-center my-4">📚 Danh sách khóa học</h2>

<div class="row row-cols-1 row-cols-md-3 g-4">
  {{#each courses}}
  <div class="col">
    <div class="card h-100 shadow-sm border-0">
      <img src="{{thumbnail}}" class="card-img-top" alt="{{title}}"
        style="height: 180px; object-fit: contain; background-color: #f9f9f9;">
      <div class="card-body">
        <h5 class="card-title text-primary fw-bold">{{title}}</h5>


        <p class="card-text text-muted mb-1">{{short_desc}}</p>
        <p class="text-secondary small mb-2">{{description}}</p>
        <p class="card-text text-muted small mb-1">
          Lĩnh vực: <strong>{{this.category}}</strong>
        </p>
        <p class="card-text text-muted small mb-1">
          Giảng viên: <strong>{{this.instructor_name}}</strong>
        </p>

        <div class="d-flex align-items-center mb-2">
          <span class="fw-bold text-warning me-1">{{this.rating_avg}}</span>

          {{{generateStars this.rating_avg}}}

          <span class="text-muted ms-1 small">({{this.rating_count}})</span>
        </div>

        <div class="mt-3">
          {{#if sale_price}}
          <span class="text-danger fw-bold">{{formatVnd sale_price}}</span>
          <span class="text-muted text-decoration-line-through ms-2">{{formatVnd price}}</span>
          {{else}}
          <span class="fw-bold">{{formatVnd price}}</span>
          {{/if}}
        </div>
      </div>

      <div class="card-footer bg-transparent border-0 d-flex justify-content-end align-items-center gap-2">

        <form action="/cart/add" method="POST" class="d-inline">
          <input type="hidden" name="course_id" value="{{this.id}}">

          <button type="submit" class="btn btn-success btn-sm">
            <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
          </button>
        </form>
        <a href="/courses/{{this.id}}" class="btn btn-outline-primary btn-sm">
          <i class="bi bi-info-circle"></i> Xem chi tiết
        </a>
      </div>
    </div>
  </div>
  {{/each}}
</div>

{{#unless courses.length}}
<div class="text-center my-5 text-muted">
  <i class="bi bi-emoji-frown fs-1"></i>
  <p>Chưa có khóa học nào.</p>
</div>
{{/unless}}
{{> pagination}}