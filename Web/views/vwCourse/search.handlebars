<div class="container mt-5">

    <h2 class="mb-4 fw-bold">
        Kết quả tìm kiếm cho: <span class="text-primary">"{{query}}"</span>
    </h2>

    <div class="row mb-3">
        <div class="col-md-4">
            <form action="/search" method="GET" id="sortForm">

                <input type="hidden" name="q" value="{{query}}">

                <label for="sortSelect" class="form-label fw-bold">Sắp xếp theo:</label>
                <select class="form-select" name="sort" id="sortSelect" onchange="this.form.submit()">
                    <option value="default" {{#if_eq sort "default" }}selected{{/if_eq}}>
                        Liên quan nhất (Mặc định)
                    </option>
                    <option value="rating_desc" {{#if_eq sort "rating_desc" }}selected{{/if_eq}}>
                        Điểm đánh giá giảm dần
                    </option>
                    <option value="price_asc" {{#if_eq sort "price_asc" }}selected{{/if_eq}}>
                        Giá tăng dần
                    </option>
                </select>
            </form>
        </div>
    </div>


    {{#if empty}}
    <div class="alert alert-warning" role="alert">
        Không tìm thấy khóa học nào phù hợp. [cite: 16, 17]
    </div>
    {{else}}

    <div class="row row-cols-1 row-cols-md-3 g-4">
        {{#each courses}}
        <div class="col">
            <div class="card shadow-sm h-100 border-0">
                <img src="{{this.thumbnail}}" class="card-img-top" alt="{{this.title}}"
                    style="height: 180px; object-fit: cover;">

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-truncate">{{this.title}}</h5>
                    <p class="card-text text-muted small">{{this.category}}</p>

                    <div class="d-flex align-items-center mb-1">
                        <span class="fw-bold text-warning me-1">{{this.rating_avg}}</span>
                        {{{generateStars this.rating_avg}}}
                        <span class="text-muted ms-1 small">({{this.rating_count}})</span>
                    </div>

                    <div class="mt-auto">
                        <div>
                            {{#if this.sale_price}}
                            <span class="fw-bold text-primary fs-5">{{formatVnd this.sale_price}}</span>
                            <span class="text-muted text-decoration-line-through ms-1 small">{{formatVnd
                                this.price}}</span>
                            {{else}}
                            <span class="fw-bold text-primary fs-5">{{formatVnd this.price}}</span>
                            {{/if}}
                        </div>

                        <div class="d-flex align-items-center mt-2 gap-2">

                            <form action="/cart/add" method="POST" style="flex-grow: 1;">
                                <input type="hidden" name="course_id" value="{{this.id}}">
                                <button type="submit" class="btn btn-success btn-sm w-100">
                                    <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                                </button>
                            </form>

                            <a href="/courses/{{this.id}}" class="btn btn-outline-primary btn-sm" title="Xem chi tiết">
                                <i class="bi bi-info-circle"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{/each}}
    </div>
    {{/if}}
    {{> pagination}}
</div>