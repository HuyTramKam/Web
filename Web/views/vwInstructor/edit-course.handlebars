<div class="container mt-5">
    <h2 class="text-primary mb-4">Chỉnh sửa khóa học</h2>

    <form method="POST" enctype="multipart/form-data" action="/instructor/edit/{{course.id}}">
        <div class="mb-3">
            <label class="form-label">Tiêu đề khóa học</label>
            <input type="text" name="title" class="form-control" value="{{course.title}}" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Mô tả ngắn</label>
            <input type="text" name="short_desc" class="form-control" value="{{course.short_desc}}">
        </div>

        <div class="mb-3">
            <label class="form-label">Mô tả chi tiết</label>
            <textarea name="full_desc" class="form-control" rows="5">{{course.full_desc}}</textarea>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Giá gốc (VND)</label>
                <input type="number" name="price" class="form-control" value="{{course.price}}">
            </div>
            <div class="col-md-6">
                <label class="form-label">Giá khuyến mãi (VND)</label>
                <input type="number" name="sale_price" class="form-control" value="{{course.sale_price}}">
            </div>
        </div>

        <div class="mb-3">
            <label for="category" class="form-label fw-bold">Lĩnh vực</label>
            <select class="form-select" id="category" name="category" required>
                <option value="">Chọn lĩnh vực</option>
                {{#each categories}}
                <option value="{{this.id}}" {{#ifCond this.id ../course.category}}selected{{/ifCond}}>
                    {{this.name}}
                </option>
                {{/each}}
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Ảnh Thumbnail</label>
            <input type="file" name="thumbnail" class="form-control">
        </div>

        <div class="text-end">
            <a href="/instructor/dashboard" class="btn btn-outline-secondary">Hủy</a>
            <button type="submit" class="btn btn-success">Lưu thay đổi</button>
        </div>
    </form>
</div>