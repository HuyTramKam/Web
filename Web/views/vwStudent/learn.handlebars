<link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css"/>

<div class="row g-4 mt-3">
  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-body">
        <h4 class="mb-2">{{current.title}}</h4>
        {{#if progress.is_completed}}
          <span class="badge bg-success">Đã hoàn thành</span>
        {{else}}
          <span class="badge bg-secondary">Đang học: {{format_number progress.watched_percent}}%</span>
        {{/if}}

        <video id="player" playsinline controls style="width:100%; max-height:520px;">
          <source src="{{current.video_url}}" type="video/mp4"/>
        </video>

        <div class="small text-muted mt-2">
          Tự động lưu tiến trình khi bạn xem.
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm h-100">
      <div class="card-header bg-light fw-semibold">Danh sách bài học</div>
      <div class="list-group list-group-flush">
        {{#each lectures as |lec|}}
          <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center
                    {{#if (eq lec.id ../current.id)}}active text-white{{/if}}"
             href="/student/courses/{{../courseId}}/{{lec.id}}">
            <span>{{lec.ord}}. {{lec.title}}</span>
            {{#if lec.duration_sec}}<span class="small">{{formatDuration lec.duration_sec}}</span>{{/if}}
          </a>
        {{/each}}
      </div>
    </div>
  </div>
  <a href="/student/courses" class="btn btn-link mt-3">
    <i class="bi bi-arrow-left"></i> Quay lại
  </a>
</div>


<script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>

<script>
  const player = new Plyr('#player');

 
  const lastSecond = Number('{{progress.last_second}}') || 0;
  player.on('loadedmetadata', () => {
    try {
      if (lastSecond > 0 && isFinite(player.duration) && lastSecond < player.duration) {
        player.currentTime = lastSecond;
      }
    } catch (_) {}

  
    const dur = Math.floor(player?.duration || 0);
    if (dur > 0) {
      fetch('/student/api/lecture-duration', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          lecture_id: {{current.id}},
          duration_sec: dur
        })
      }).catch(() => {});
    }
  });


  let lastSent = 0;

  function sendProgress(force = false) {
    if (!player || !isFinite(player.duration) || player.duration <= 0) return;

    const pos = Math.max(0, Math.floor(player.currentTime || 0));
    const dur = Math.max(1, Math.floor(player.duration || 1));


    if (!force && Math.abs(pos - lastSent) < 3) return;
    lastSent = pos;

    fetch('/student/api/progress', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        lecture_id: {{current.id}},
        last_second: pos,
        duration_sec: dur
      })
    }).catch(() => {});
  }

  // Gửi đều khi xem
  player.on('timeupdate', () => sendProgress(false));
  // Hoàn tất clip
  player.on('ended', () => sendProgress(true));
  // Tạm dừng cũng flush
  player.on('pause', () => sendProgress(true));
  // Rời tab / đóng trang
  window.addEventListener('beforeunload', () => sendProgress(true));
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) sendProgress(true);
  });
</script>
