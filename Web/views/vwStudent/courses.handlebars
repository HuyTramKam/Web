<h2 class="my-4 text-center">
  <i class="bi bi-bag-check-fill text-success"></i>
  Danh sách khóa học đã mua
</h2>

{{#if purchasedCourses.length}}
<div class="row row-cols-1 row-cols-md-3 g-4">
  {{#each purchasedCourses as |course|}}
  <div class="col">
    <div class="card h-100 shadow-sm border-0">
      <div class="position-relative">
        <img src="{{course.thumbnail}}" alt="{{course.course_title}}" class="card-img-top"
          style="height:180px; object-fit:contain; background:#f9f9f9;">
        {{#if course.is_completed}}
        <span class="position-absolute top-0 start-0 m-2 badge bg-success-subtle text-success border">
          <i class="bi bi-check2-circle"></i> Đã hoàn thành
        </span>
        {{/if}}
      </div>

      <div class="card-body">
        <h5 class="card-title">{{course.course_title}}</h5>

        {{#if course.short_desc}}
        <p class="card-text text-muted small">{{course.short_desc}}</p>
        {{/if}}

        {{#if course.sale_price}}
        <div class="mt-2">
          <span class="text-danger fw-bold">{{formatVnd course.sale_price}}</span>
          <span class="text-muted text-decoration-line-through ms-2">{{formatVnd course.price}}</span>
        </div>
        {{else}}
        {{#if course.price}}
        <div class="mt-2 fw-bold">{{formatVnd course.price}}</div>
        {{/if}}
        {{/if}}

  
        {{#unless course.is_completed}}
        <div class="mt-3">
          <div class="progress" style="height:6px;">
            <div class="progress-bar" role="progressbar" style="width: {{course.completion_percent}}%;"
              aria-valuenow="{{course.completion_percent}}" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <small class="text-muted">{{course.completion_percent}}% đã học</small>
        </div>
        {{/unless}}
      </div>

      <div class="card-footer bg-transparent border-0 text-end">
        <a href="/student/courses/{{course.course_id}}" class="btn btn-outline-primary btn-sm">
          <i class="bi bi-play-circle"></i> Vào học
        </a>
      </div>
    </div>
  </div>
  {{/each}}
</div>
{{else}}
<div class="text-center text-muted my-5">
  <i class="bi bi-emoji-frown fs-1"></i>
  <p>Bạn chưa mua khóa học nào.</p>
  <a href="/courses" class="btn btn-primary">Khám phá khóa học</a>
</div>
{{/if}}