<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Online Academy</title>




  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <!-- CSS của bạn -->
  <link rel="stylesheet" href="/static/style.css">
  {{{_sections.css}}}
</head>

<body class="theme-blue">


  <header>
    <nav class="navbar navbar-expand-lg bg-white border-bottom shadow-sm py-3">
      <div class="container-fluid">

        <!-- Logo -->
        <a class="navbar-brand" href="/">
          <img src="/static/imgs/logo.png" alt="Online Academy Logo" height="40" class="me-2">
        </a>

        <!-- Khám phá -->
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownCategories" role="button"
              data-bs-toggle="dropdown" aria-expanded="false">
              Khám phá
            </a>
            <ul class="dropdown-menu" aria-labelledby="navbarDropdownCategories">

              {{#each categories}}
              <li>
                <a class="dropdown-item fw-bold" href="/categories/{{this.id}}">
                  {{this.catname}}
                </a>
              </li>

              {{#if this.children}}
              {{#each this.children}}
              <li>
                <a class="dropdown-item ps-4" href="/categories/{{this.id}}">
                  ↳ {{this.catname}}
                </a>
              </li>
              {{/each}}
              {{/if}}
              {{/each}}

              <li>
                <hr class="dropdown-divider">
              </li>
              <li><a class="dropdown-item" href="/courses">Tất cả khóa học</a></li>
            </ul>
          </li>
        </ul>

        <!-- Search -->
        <form class="d-flex flex-grow-1 mx-3 navbar-search" role="search" action="/search" method="get">
          <div class="input-group">
            <button class="btn btn-light border" type="submit" id="button-search" aria-label="Tìm kiếm">
              <i class="bi bi-search"></i>
            </button>
            <input class="form-control" type="search" name="q" placeholder="Tìm kiếm khóa học" aria-label="Search">
          </div>
        </form>

        <!-- Actions phải -->
        <div class="d-flex align-items-center">

          <!-- Cart -->
          <a href="/cart" class="nav-link mx-2 position-relative" aria-label="Giỏ hàng">
            <i class="bi bi-cart fs-4"></i>

            {{#if cartTotal}}
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
              {{cartTotal}}
              <span class="visually-hidden">mặt hàng trong giỏ</span>
            </span>
            {{/if}}
          </a>

          <!-- User -->
          {{#if isAuthenticated}}
          <div class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="navbarDropdownUser" role="button"
              data-bs-toggle="dropdown" aria-expanded="false">
              👋 Welcome,&nbsp;<strong>{{authUser.name}}</strong>
            </a>

            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-3"
              aria-labelledby="navbarDropdownUser">
              <li>
                <a class="dropdown-item d-flex align-items-center gap-2" href="/{{authUser.role}}/profile">
                  <i class="bi bi-person fs-5 text-primary"></i>
                  <span>My Profile</span>
                </a>
              </li>

              {{#if (eq authUser.role "instructor")}}
              <li>
                <a class="dropdown-item d-flex align-items-center gap-2" href="/instructor/dashboard">
                  <i class="bi bi-journal-text fs-5 text-primary"></i>
                  <span>My Courses</span>
                </a>
              </li>
              {{else if (eq authUser.role "student")}}
              <li>
                <a class="dropdown-item d-flex align-items-center gap-2" href="/student/courses">
                  <i class="bi bi-journal-text fs-5 text-primary"></i>
                  <span>My Courses</span>
                </a>
              </li>
              {{/if}}

              <li>
                <hr class="dropdown-divider my-1">
              </li>

              <li>
                <form action="/account/signout" method="post" class="m-0">
                  <button type="submit" class="dropdown-item d-flex align-items-center gap-2 text-danger">
                    <i class="bi bi-box-arrow-right fs-5"></i>
                    <span>Logout</span>
                  </button>
                </form>
              </li>
            </ul>
          </div>

          {{else}}
          <a class="btn btn-outline-dark mx-1" href="/account/signin">Sign in</a>
          <a class="btn btn-dark mx-1" href="/account/signup">Sign up</a>
          {{/if}}

        </div>

      </div>
    </nav>
  </header>

  <!-- Main -->
  <main class="container-fluid mt-3">
    {{{body}}}
  </main>

  {{{_sections.js}}}

  <!-- JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>