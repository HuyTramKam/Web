<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Online Academy</title>

  <!-- Bootstrap & Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@3.7.1/dist/chart.min.js"></script>

  <style>
    body { background-color: #f8f9fa; }
    .dashboard-header {
      background: linear-gradient(90deg, #4e73df 0%, #224ebe 100%);
      color: white; padding: 30px 0; margin-bottom: 30px;
      border-radius: 0 0 15px 15px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    .stat-card { background:white; border-radius:10px; padding:20px; margin-bottom:20px;
      box-shadow:0 0 10px rgba(0,0,0,0.05); transition: transform 0.2s;
    }
    .stat-card:hover { transform: translateY(-5px); }
    .stat-card .icon { font-size: 2.5rem; opacity: 0.7; }
    .stat-value { font-size: 2rem; font-weight: 700; }
    .chart-container { background:white; border-radius:10px; padding:20px;
      box-shadow:0 0 10px rgba(0,0,0,0.05); margin-bottom:30px;
    }
  </style>
</head>

<body>
  <div class="dashboard-header text-center">
    <h1><i class="bi bi-speedometer2"></i> Trang quản trị hệ thống</h1>
    <p>Chào mừng, {{user.name}}! (Quyền: {{user.permission}})</p>
  </div>

  <main class="container">

    <!-- Khu vực quản lý nhanh -->
    <h2 class="mb-4 text-center text-primary">Các Chức năng Quản lý</h2>
    <div class="row g-4 mb-5 justify-content-center">
      <div class="col-md-4 col-lg-3">
        <a href="/admin/categories" class="btn btn-primary w-100 py-3 shadow">
          <i class="bi bi-tag-fill me-2"></i> Quản lý Lĩnh vực
        </a>
      </div>
      <div class="col-md-4 col-lg-3">
        <a href="/admin/courses" class="btn btn-success w-100 py-3 shadow">
          <i class="bi bi-book-half me-2"></i> Quản lý Khóa học
        </a>
      </div>
      <div class="col-md-4 col-lg-3">
        <a href="/admin/users" class="btn btn-warning w-100 py-3 shadow text-white">
          <i class="bi bi-people-fill me-2"></i> Quản lý Người dùng
        </a>
      </div>
    </div>

    <!-- Khu vực thống kê -->
    <h2 class="mb-4 text-primary">Thống kê Tổng quan</h2>
    <div class="row g-4">
      <div class="col-xl-3 col-md-6">
        <div class="stat-card border-start border-primary border-5">
          <div class="d-flex align-items-center">
            <div class="flex-grow-1">
              <div class="fw-bold text-primary text-uppercase mb-1">Tổng Khóa học</div>
              <div class="stat-value">{{stats.totalCourses}}</div>
              <div class="text-muted"><i class="bi bi-arrow-up-right"></i> {{stats.publishedCourses}} đang hoạt động</div>
            </div>
            <i class="bi bi-journals icon text-primary"></i>
          </div>
        </div>
      </div>

      <div class="col-xl-3 col-md-6">
        <div class="stat-card border-start border-success border-5">
          <div class="d-flex align-items-center">
            <div class="flex-grow-1">
              <div class="fw-bold text-success text-uppercase mb-1">Tổng Học viên</div>
              <div class="stat-value">{{stats.totalStudents}}</div>
              <div class="text-muted"><i class="bi bi-person-check"></i> Mới tháng này: {{stats.newStudentsThisMonth}}</div>
            </div>
            <i class="bi bi-mortarboard-fill icon text-success"></i>
          </div>
        </div>
      </div>

      <div class="col-xl-3 col-md-6">
        <div class="stat-card border-start border-warning border-5">
          <div class="d-flex align-items-center">
            <div class="flex-grow-1">
              <div class="fw-bold text-warning text-uppercase mb-1">Tổng Giảng viên</div>
              <div class="stat-value">{{stats.totalInstructors}}</div>
              <div class="text-muted"><i class="bi bi-person-fill-gear"></i> Giảng viên mới: {{stats.newInstructors}}</div>
            </div>
            <i class="bi bi-person-lines-fill icon text-warning"></i>
          </div>
        </div>
      </div>

      <div class="col-xl-3 col-md-6">
        <div class="stat-card border-start border-info border-5">
          <div class="d-flex align-items-center">
            <div class="flex-grow-1">
              <div class="fw-bold text-info text-uppercase mb-1">Tổng Lĩnh vực</div>
              <div class="stat-value">{{stats.totalCategories}}</div>
              <div class="text-muted"><i class="bi bi-tag"></i> Đã được phân loại</div>
            </div>
            <i class="bi bi-grid-fill icon text-info"></i>
          </div>
        </div>
      </div>
    </div>

  </main>

  <footer class="text-center mt-5 p-3 bg-light border-top">
    <small>© 2025 Online Academy. All rights reserved.</small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  
</body>
</html>
