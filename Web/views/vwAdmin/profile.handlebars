<body>
    <!-- Header -->



    <!-- Main -->
    <main class="container mt-5" style="max-width: 700px;">
        <h3 class="text-center mb-4">📋 Hồ sơ admin</h3>

        <!-- Thông tin cá nhân -->
        <form action="/admin/profile" method="post">
            <input type="hidden" name="id" value="{{user.id}}">

            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-person-badge"></i> Thông tin cá nhân
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="name" class="form-label">Họ và tên</label>
                        <input type="text" id="name" name="name" class="form-control" value="{{user.name}}" required>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" id="email" name="email" class="form-control" value="{{user.email}}"
                            required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Quyền truy cập</label>
                        <input type="text" class="form-control" value="{{user.permission}}" disabled>
                    </div>

                    <div class="text-end">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-save"></i> Lưu thay đổi
                        </button>
                    </div>
                </div>
            </div>
        </form>

        <!-- Đổi mật khẩu -->
        <form action="/student/change-pwd" method="post">
            <input type="hidden" name="id" value="{{user.id}}">

            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <i class="bi bi-key"></i> Đổi mật khẩu
                </div>
                <div class="card-body">
                    {{#if error}}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <strong>Lỗi!</strong> Mật khẩu hiện tại không đúng.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    {{/if}}

                    <div class="mb-3">
                        <label for="currentPassword" class="form-label">Mật khẩu hiện tại</label>
                        <input type="password" id="currentPassword" name="currentPassword" class="form-control"
                            required>
                    </div>

                    <div class="mb-3">
                        <label for="newPassword" class="form-label">Mật khẩu mới</label>
                        <input type="password" id="newPassword" name="newPassword" class="form-control" required>
                    </div>

                    <div class="text-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-shield-lock"></i> Đổi mật khẩu
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </main>
</body>