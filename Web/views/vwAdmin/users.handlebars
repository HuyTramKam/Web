<h2 class="text-center mt-4 mb-4">Quản lý Người dùng</h2>

<div class="container">

  {{!-- ====== BẢNG GIẢNG VIÊN ====== --}}
  <h4 class="mt-4 mb-3 text-primary">
    <i class="bi bi-person-badge"></i> Danh sách Giảng viên
  </h4>

  <table class="table table-striped table-bordered align-middle">
    <thead class="table-dark text-center">
      <tr>
        <th>#</th>
        <th>Họ và tên</th>
        <th>Email</th>
        <th>Ngày sinh</th>
        <th>Hành động</th>
      </tr>
    </thead>
    <tbody>
      {{#if teachers.length}}
        {{#each teachers}}
        <tr class="text-center">
          <td>{{@index}}</td>
          <td>{{this.name}}</td>
          <td>{{this.email}}</td>
          <td>{{this.dob}}</td>
          <td>
            <div class="d-flex justify-content-center gap-2">
              {{#if this.is_disabled}}
                <form action="/admin/users/disable/{{this.id}}" method="POST" style="display:inline;">
                  <input type="hidden" name="disable" value="false">
                  <button type="submit" class="btn btn-sm btn-success">Mở lại</button>
                </form>
              {{else}}
                <form action="/admin/users/disable/{{this.id}}" method="POST" style="display:inline;">
                  <input type="hidden" name="disable" value="true">
                  <button type="submit" class="btn btn-sm btn-warning">Khoá</button>
                </form>
              {{/if}}

              <form action="/admin/user/delete/{{this.id}}" method="POST" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa giảng viên này?');">
                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
              </form>
            </div>
          </td>
        </tr>
        {{/each}}
      {{else}}
        <tr>
          <td colspan="6" class="text-center text-muted">Chưa có giảng viên nào.</td>
        </tr>
      {{/if}}
    </tbody>
  </table>

  {{!-- ====== BẢNG SINH VIÊN ====== --}}
  <h4 class="mt-5 mb-3 text-success">
    <i class="bi bi-people"></i> Danh sách Sinh viên
  </h4>

  <table class="table table-striped table-bordered align-middle">
    <thead class="table-dark text-center">
      <tr>
        <th>#</th>
        <th>Họ và tên</th>
        <th>Email</th>
        <th>Ngày sinh</th>
        <th>Hành động</th>
      </tr>
    </thead>
    <tbody>
      {{#if students.length}}
        {{#each students}}
        <tr class="text-center">
          <td>{{@index}}</td>
          <td>{{this.name}}</td>
          <td>{{this.email}}</td>
          <td>{{this.dob}}</td>
          <td>
            <div class="d-flex justify-content-center gap-2">
              {{#if this.is_disabled}}
                <form action="/admin/users/disable/{{this.id}}" method="POST" style="display:inline;">
                  <input type="hidden" name="disable" value="false">
                  <button type="submit" class="btn btn-sm btn-success">Mở lại</button>
                </form>
              {{else}}
                <form action="/admin/users/disable/{{this.id}}" method="POST" style="display:inline;">
                  <input type="hidden" name="disable" value="true">
                  <button type="submit" class="btn btn-sm btn-warning">Khoá</button>
                </form>
              {{/if}}

              <form action="/admin/users/make-teacher/{{this.id}}" method="POST" style="display:inline;" onsubmit="return confirm('Cấp quyền giảng viên cho sinh viên này?');">
                <button type="submit" class="btn btn-sm btn-primary">Cấp quyền GV</button>
              </form>

              <form action="/admin/users/delete/{{this.id}}" method="POST" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa sinh viên này?');">
                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
              </form>
            </div>
          </td>
        </tr>
        {{/each}}
      {{else}}
        <tr>
          <td colspan="6" class="text-center text-muted">Chưa có sinh viên nào.</td>
        </tr>
      {{/if}}
    </tbody>
  </table>

</div>
