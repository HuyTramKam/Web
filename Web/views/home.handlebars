<div class="container mt-5">
<section class="hero-brand rounded-4 p-5 mb-5 text-center">
    <h1 class="fw-bold text-white mb-2">Online Academy – Học thông minh, bứt phá nhanh</h1>
    <p class="text-white-50 mb-4">Hàng trăm khóa học chất lượng được cập nhật mỗi tuần.</p>
    <a href="/courses" class="btn btn-brand-lg px-4 py-2">
        <i class="bi bi-compass"></i> Khám phá ngay
    </a>
</section>

    <h2 class="mb-4 fw-bold">🔥 Khóa học nổi bật trong tuần</h2>
    <div class="row row-cols-1 row-cols-md-4 g-4">
        {{#each outstandingCourses}}
        <div class="col">
            <div class="card course-card h-100">

                <img src="{{this.thumbnail}}" class="card-img-top" alt="{{this.title}}">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-truncate">{{this.title}}</h5>

                    {{#if this.short_desc}}
                    <p class="card-text text-muted small text-truncate-2">{{this.short_desc}}</p>
                    {{/if}}

                    <p class="card-text text-muted small mb-1">
                        Lĩnh vực: <strong>{{this.category}}</strong>
                    </p>
                    <p class="card-text text-muted small mb-1">
                        Giảng viên: <strong>{{this.instructor_name}}</strong>
                    </p>

                    <div class="d-flex align-items-center mb-1">
                        <span class="fw-bold text-warning me-1">{{this.rating_avg}}</span>
                        {{{generateStars this.rating_avg}}}
                        <span class="text-muted ms-1 small">({{this.rating_count}})</span>
                    </div>

                    <div class="mt-auto">
                        <div>
                            {{#if this.sale_price}}
                            <span class="price-now fs-5">{{formatVnd this.sale_price}}</span>
                            <span class="price-old ms-1 small">{{formatVnd this.price}}</span>
                            {{else}}
                            <span class="price-now fs-5">{{formatVnd this.price}}</span>
                            {{/if}}
                        </div>

                        <div class="d-flex align-items-center mt-2 gap-2">
                            {{#if_contains ../ownedCourseIds this.id}}
                            <a href="/student/my-courses" class="btn btn-outline-success btn-sm w-100 disabled">
                                <i class="bi bi-check-circle"></i> Đã sở hữu
                            </a>
                            {{else}}
                            <form action="/cart/add" method="POST" style="flex-grow: 1;">
                                <input type="hidden" name="course_id" value="{{this.id}}">
                                <button type="submit" class="btn btn-success btn-sm w-100">
                                    <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                                </button>
                            </form>
                            {{/if_contains}}

                            <a href="/courses/{{this.id}}" class="btn btn-outline-primary btn-sm" title="Xem chi tiết">
                                <i class="bi bi-info-circle"></i>
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        </div>
        {{/each}}
    </div>

    <hr class="my-5">

