<div class="row">
    <div class="col-md-8">

        <div class="mb-3">
            <label for="courseTitle" class="form-label fw-bold">
                Tiêu đề Khóa học <span class="text-danger">*</span>
            </label>
            <input type="text" class="form-control" id="courseTitle" name="title" value="{{course.title}}"
                placeholder="Nhập tiêu đề khóa học" required>
        </div>

        <div class="mb-3">
            <label for="shortDesc" class="form-label fw-bold">
                Mô tả Ngắn gọn <span class="text-danger">*</span>
            </label>
            <input type="text" class="form-control" id="shortDesc" name="short_desc" value="{{course.short_desc}}"
                placeholder="Tóm tắt ngắn (dưới 100 ký tự)" required>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Mô tả Chi tiết</label>
            <div id="editor" style="height: 200px; border: 1px solid #ced4da; border-radius: 6px;">
                {{{course.full_desc}}}
            </div>
            <input type="hidden" name="full_desc" id="txtFullDesc" required>
            <small class="text-muted">Bạn có thể in đậm, gạch đầu dòng, chèn link, đoạn code, v.v.</small>
        </div>

    </div>

    <div class="col-md-4">

        <div class="mb-3">
            <label for="courseCategory" class="form-label fw-bold">Lĩnh Vực <span class="text-danger">*</span></label>
            <select class="form-select" id="category_id" name="category_id" required>
                <option value="" disabled selected>Chọn lĩnh vực</option>
                {{#each categories}}
                <option value="{{this.id}}" {{#ifCond this.id ../course.category}}selected{{/ifCond}}>
                    {{this.name}}
                </option>
                {{/each}}
            </select>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="coursePrice" class="form-label fw-bold">Giá Gốc (VNĐ) <span
                        class="text-danger">*</span></label>
                <input type="number" class="form-control" id="coursePrice" name="price" value="{{course.price}}"
                    placeholder="1.000.000" min="0" required>
            </div>
            <div class="col-md-6 mb-3">
                <label for="sale_price" class="form-label fw-bold">Giá Khuyến mãi</label>
                <input type="number" class="form-control" id="sale_price" name="sale_price"
                    value="{{course.sale_price}}" placeholder="800.000" min="0">
            </div>
        </div>

        <div class="mb-3">
            <label for="courseThumbnail" class="form-label fw-bold">Ảnh Thumbnail <span
                    class="text-danger">*</span></label>    
            <input class="form-control" type="file" id="courseThumbnail" name="thumbnail" accept="image/*" {{#unless
                course.thumbnail_url}}required{{/unless}}>

            {{#if course.thumbnail_url}}
            <div class="mt-2 text-center">
                <small class="text-muted d-block mb-1">Ảnh hiện tại:</small>
                <img src="{{course.thumbnail_url}}" class="img-fluid rounded border"
                    style="max-height: 100px; object-fit: cover;" alt="Thumbnail khóa học">
            </div>
            {{/if}}
        </div>

    </div>


</div>